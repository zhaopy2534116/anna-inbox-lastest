{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "chat.write_message"
  ],
  "host_capabilities": [
    "llm.sample",
    "llm.complete",
    "aps.scope.user.read",
    "aps.scope.user.write"
  ],
  "required_executas": [
    {
      "tool_id": "tool-zhaopy-inbox-tool-373sf2et",
      "min_version": "1.0.0",
      "version": "lastest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "This app is a minimal Anna mail-agent skeleton. Gmail access is read from local token files owned by the project. Mail-agent evaluation can use DashScope inside the Executa or Anna Executa sampling; do not ask the user for API keys.",
  "tags": ["email", "gmail", "oauth", "llm"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Zhaopy Mail Agent",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 760, "h": 560 },
        "default_size": { "w": 980, "h": 720 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": [
        "required:tool-zhaopy-inbox-tool-373sf2et"
      ],
      "chat": [
        "write_message"
      ],
      "storage": [
        "get",
        "set",
        "list",
        "delete"
      ],
      "llm": [
        "complete"
      ],
      "window": [
        "set_title"
      ]
    },
    "csp_overrides": {
      "script-src": ["'self'"],
      "style-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": [],
    "user_id": 1
  }
}
